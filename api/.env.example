# --- Azure / Foundry ---
AZURE_SUBSCRIPTION_ID=86b37969-9445-49cf-b03f-d8866235171c
AZURE_RESOURCE_GROUP=ai-myaacoub
AZURE_TENANT_ID=

# --- Foundry Project + Agent ---
# From: https://ai.azure.com/.../002-ai-poc-private,proj-default/build/agents/sp-search
FOUNDRY_PROJECT_NAME=proj-default
FOUNDRY_ACCOUNT_NAME=002-ai-poc-private
FOUNDRY_AGENT_ID=sp-search
# Direct (non-APIM) endpoint — only used as fallback / for local dev
FOUNDRY_PROJECT_ENDPOINT=https://002-ai-poc-private.services.ai.azure.com/api/projects/proj-default

# --- APIM AI Gateway (preferred path, private VNET) ---
# Replace with your APIM gateway URL (private DNS inside the VNET)
APIM_BASE_URL=https://ai-gateway-apim-poc-my.azure-api.net
APIM_FOUNDRY_PATH=/foundry/agents
APIM_SUBSCRIPTION_KEY=

# --- Azure AI Search (Foundry IQ knowledge source) ---
AZURE_SEARCH_ENDPOINT=https://ai-search-my.search.windows.net
AZURE_SEARCH_INDEX_NAME=sp-search-index
AZURE_SEARCH_API_KEY=

# --- App config ---
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:8100,http://localhost:4200,https://localhost
